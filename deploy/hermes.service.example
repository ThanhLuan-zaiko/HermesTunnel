[Unit]
Description=Hermes Tunnel gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hermes
Group=hermes
EnvironmentFile=/etc/hermes/hermes.env
ExecStart=/usr/local/bin/hermes server --public ${HERMES_PUBLIC_ADDR} --control ${HERMES_CONTROL_ADDR} --base-domain ${HERMES_BASE_DOMAIN} --token ${HERMES_TOKEN}
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
